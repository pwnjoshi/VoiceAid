# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── AWS Core ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# ── Amazon Bedrock Knowledge Base (RAG) ───────────────────────────────────────
# Create at: https://console.aws.amazon.com/bedrock/home#/knowledge-bases
KNOWLEDGE_BASE_ID=your_knowledge_base_id
# Model ARN for RAG generation (Claude or Nova)
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.nova-lite-v1:0

# ── Amazon S3 (document storage for knowledge base) ───────────────────────────
S3_BUCKET_NAME=voiceaid-knowledge-docs

# ── Amazon Lex V2 (intent detection) ─────────────────────────────────────────
# Create bot at: https://console.aws.amazon.com/lexv2/home
LEX_BOT_ID=your_lex_bot_id
LEX_BOT_ALIAS_ID=TSTALIASID
LEX_LOCALE_ID=en_US

# ── Amazon Nova Sonic (bidirectional speech streaming) ────────────────────────
# Set to 'true' only when Nova Sonic is available in your region (preview)
NOVA_SONIC_ENABLED=false
