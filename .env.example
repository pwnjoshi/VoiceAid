# VoiceAid Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== Backend Server =====
PORT=3000
NODE_ENV=development

# ===== AWS Configuration =====
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# ===== S3 Configuration =====
S3_BUCKET_NAME=voiceaid-knowledge-docs

# ===== AWS Bedrock Configuration =====
KNOWLEDGE_BASE_ID=your_knowledge_base_id_here

# ===== Amazon Lex V2 Configuration =====
LEX_BOT_ID=your_lex_bot_id_here
LEX_BOT_ALIAS_ID=TSTALIASID
LEX_LOCALE_ID=en_US

# ===== Groq API Configuration (Fallback) =====
GROQ_API_KEY=your_groq_api_key_here

# ===== AWS Amplify Configuration =====
EXPO_PUBLIC_AWS_REGION=us-east-1
EXPO_PUBLIC_USER_POOL_ID=your_user_pool_id
EXPO_PUBLIC_USER_POOL_CLIENT_ID=your_client_id
EXPO_PUBLIC_IDENTITY_POOL_ID=your_identity_pool_id
EXPO_PUBLIC_GRAPHQL_ENDPOINT=your_graphql_endpoint
EXPO_PUBLIC_API_KEY=your_api_key
EXPO_PUBLIC_S3_BUCKET=voiceaid-knowledge-docs

# ===== Frontend Configuration =====
EXPO_PUBLIC_API_URL=http://localhost:3000

# ===== Optional: Database =====
# If using a database for caching/logging
# DATABASE_URL=your_database_url_here
